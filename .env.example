# ============================================
# JARVIS - Variables d'environnement
# ============================================
# Copie ce fichier en .env.local et remplis les valeurs.

# Clé API Groq (https://console.groq.com/keys) — tier gratuit
GROQ_API_KEY=gsk_...

# Modèle Groq à utiliser (par défaut : llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Modèle Groq pour les requêtes multimodales (analyse d'image)
# Utilisé automatiquement quand un message contient une image
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Clé API MapTiler (https://www.maptiler.com/) — tiles satellite + geocoding
# Tier gratuit 100k tiles & geocoding/mois, sans CB
# Utilisée par la page /recherche-lieu (zoom cinématique espace → adresse)
NEXT_PUBLIC_MAPTILER_KEY=

# Clé API Tavily (https://app.tavily.com/) — tier gratuit 1000 req/mois
# Active la recherche web temps réel via l'outil web_search
TAVILY_API_KEY=tvly-...

# AccessKey Picovoice (https://console.picovoice.ai/) — wake word "JARVIS"
# Tier gratuit Personal (3 utilisateurs/mois). NEXT_PUBLIC_ → exposée au client
# car Porcupine tourne dans le navigateur (WebAssembly).
NEXT_PUBLIC_PICOVOICE_KEY=

# Clé API Cartesia (https://play.cartesia.ai/) — TTS premium
# Tier gratuit ~100k caractères/mois. Active la voix JARVIS via /api/tts.
CARTESIA_API_KEY=sk_car_...

# ID de la voix Cartesia à utiliser. Parcours la bibliothèque sur
# https://play.cartesia.ai/sounds, filtre par langue "French", écoute,
# copie l'ID de la voix qui te plaît et colle-le ici.
CARTESIA_VOICE_ID=

# ElevenLabs — fallback TTS automatique quand Cartesia est en quota_exceeded.
# Tier gratuit : 10k caractères/mois. Inscription : https://elevenlabs.io/
# Clé API : https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ID de voix ElevenLabs. Défaut : Rachel (multilingue, parle FR).
# Pour une vraie voix française : https://elevenlabs.io/app/voice-library
# → filtre par "French", écoute, copie l'ID.
ELEVENLABS_VOICE_ID=

# Modèle ElevenLabs. eleven_multilingual_v2 = meilleure qualité FR.
ELEVENLABS_MODEL=eleven_multilingual_v2

# Philips Hue — contrôle local des lumières connectées
# Visite /setup/hue dans l'app pour pairer ta bridge automatiquement.
# Le wizard te donnera ces deux valeurs à coller ici.
HUE_BRIDGE_IP=
HUE_USERNAME=

# (Optionnel) URL publique de l'app
NEXT_PUBLIC_APP_URL=http://localhost:3000
