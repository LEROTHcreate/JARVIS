# ============================================
# JARVIS - Variables d'environnement
# ============================================
# Copie ce fichier en .env.local et remplis les valeurs.

# Clé API Groq (https://console.groq.com/keys) — tier gratuit
GROQ_API_KEY=gsk_...

# Modèle Groq à utiliser (par défaut : llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Modèle Groq pour les requêtes multimodales (analyse d'image)
# Utilisé automatiquement quand un message contient une image
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Clé API Tavily (https://app.tavily.com/) — tier gratuit 1000 req/mois
# Active la recherche web temps réel via l'outil web_search
TAVILY_API_KEY=tvly-...

# AccessKey Picovoice (https://console.picovoice.ai/) — wake word "JARVIS"
# Tier gratuit Personal (3 utilisateurs/mois). NEXT_PUBLIC_ → exposée au client
# car Porcupine tourne dans le navigateur (WebAssembly).
NEXT_PUBLIC_PICOVOICE_KEY=

# Clé API Cartesia (https://play.cartesia.ai/) — TTS premium
# Tier gratuit ~100k caractères/mois. Active la voix JARVIS via /api/tts.
CARTESIA_API_KEY=sk_car_...

# ID de la voix Cartesia à utiliser. Parcours la bibliothèque sur
# https://play.cartesia.ai/sounds, filtre par langue "French", écoute,
# copie l'ID de la voix qui te plaît et colle-le ici.
CARTESIA_VOICE_ID=

# (Optionnel) URL publique de l'app
NEXT_PUBLIC_APP_URL=http://localhost:3000
